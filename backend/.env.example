MONGO_URI=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Required for manual sync routes (POST /api/sync/*)
SYNC_SECRET=

# Auto-injected by Vercel when crons are configured in vercel.json — do NOT set manually on Vercel.
# For local testing of /api/cron/chunk, set any value here.
CRON_SECRET=

# football-data.org free-tier key — get yours at https://www.football-data.org/client/register
# Free tier: 10 requests per 10 minutes; the client auto-throttles (11-min sliding window)
FOOTBALL_DATA_API_KEY=

# Override the season used by all sync steps (default: auto-detected from current date)
# Format: 4-digit year of season start (e.g. 2024 for the 2024/25 season)
# FOOTBALL_DATA_SEASON=2024
# SYNC_SEASON=2025

# Set to "fake" to run seed.js with static fixture data (no API calls, fast local dev)
# SEED_MODE=fake
