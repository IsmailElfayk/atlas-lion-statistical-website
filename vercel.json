{
  "version": 2,
  "buildCommand": "npm run vercel-build",
  "outputDirectory": "frontend/dist",
  "functions": {
    "backend/server.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/backend/server.js" },
    { "source": "/(.*)",       "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/cron/chunk",
      "schedule": "*/11 * * * *"
    }
  ]
}
